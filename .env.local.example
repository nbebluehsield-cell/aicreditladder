# Copy to .env.local and fill in values.

# --- Site (required in production on your real domain) ---
# Must match the browser origin and Supabase Auth → URL Configuration → Site URL
# Use .com (not .co) — typo breaks DNS and magic links.
# Magic links redirect to: .../auth/callback?next=/internal/path
# In Supabase → Redirect URLs, allow that host with a wildcard if needed, e.g.
#   https://www.aicreditladder.com/auth/callback*
#   https://*.vercel.app/auth/callback*
NEXT_PUBLIC_SITE_URL=https://www.aicreditladder.com

# --- Supabase (required for auth + DB) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: newsletter upsert on sign-in / API routes. Never expose in client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Analytics 4 (optional — loads after cookie consent) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-N1KVEX5T3W

# --- Ads (optional) ---
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# NEXT_PUBLIC_ADSENSE_SLOT_HOME_INLINE=
# NEXT_PUBLIC_ADSENSE_SLOT_EXPLORE_INLINE=
# NEXT_PUBLIC_ADSENSE_SLOT_OFFER_RAIL=
